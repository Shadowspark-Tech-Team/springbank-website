# Spring Bank – Environment Variables Template
# Copy to .env and fill in your values. NEVER commit .env to source control.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://user:password@localhost:5432/springbank

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
REFRESH_SECRET=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# ─── Email (optional) ────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@springbank.com
CONTACT_TO_EMAIL=support@springbank.com
