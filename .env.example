# Pooled connection URL used by Next.js runtime and Prisma Client
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/springbank?schema=public"

# Direct (non-pooled) URL used by Prisma Migrate/Studio
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/springbank?schema=public"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
