# Pooled connection URL used by Next.js runtime and Prisma Client (Neon/Supabase/Prisma Postgres compatible)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/springbank?schema=public"

# Direct (non-pooled) URL used by Prisma Migrate/Studio for reliable schema operations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/springbank?schema=public"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
